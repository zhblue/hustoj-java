        <location>/WEB-INF/views/error500.jsp</location>
    </error-page>

    <!-- Session Config -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure>
            <same-site>Strict</same-site>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>
